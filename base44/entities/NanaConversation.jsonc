{
  "name": "NanaConversation",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "user",
        "nana"
      ],
      "description": "Siapa yang kirim pesan"
    },
    "message": {
      "type": "string",
      "description": "Isi pesan"
    },
    "session_date": {
      "type": "string",
      "format": "date",
      "description": "Tanggal sesi chat"
    },
    "mood": {
      "type": "string",
      "description": "Mood user saat pesan dikirim"
    },
    "message_type": {
      "type": "string",
      "enum": [
        "chat",
        "roast",
        "analysis",
        "mood_response"
      ],
      "default": "chat",
      "description": "Tipe pesan"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Deskripsi percakapan Nana (opsional)"
    }
  },
  "required": [
    "role",
    "message",
    "session_date"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}